# Route all requests to the front controller (index.php) so /Medicus/login, /Medicus/register, etc. work
RewriteEngine On
RewriteBase /Medicus/
# If the request is not for an existing file or directory, send to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
